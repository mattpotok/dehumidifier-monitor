[Unit]
Description=Dehumidifier Telegram proxy
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/dehumidifier-monitor/telegram-proxy
EnvironmentFile=/opt/dehumidifier-monitor/telegram-proxy/.env
ExecStart=/opt/dehumidifier-monitor/telegram-proxy/telegram-proxy
Restart=on-failure
RestartSec=5

# Basic hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true

[Install]
WantedBy=multi-user.target
